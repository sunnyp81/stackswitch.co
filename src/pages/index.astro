---
import Base from '../layouts/Base.astro';
import { getAllTools, formatPrice, CATEGORIES } from '../utils/tools';
import HeroIllustration from '../components/HeroIllustration.astro';
import CategoryIcon from '../components/CategoryIcon.astro';

const tools = await getAllTools();

// Group by category
const byCategory: Record<string, typeof tools> = {};
for (const tool of tools) {
  if (!byCategory[tool.category]) byCategory[tool.category] = [];
  byCategory[tool.category].push(tool);
}

// Featured tools
const featured = tools
  .filter((t) => ['hubspot', 'salesforce', 'deel', 'vanta', 'notion', 'figma'].includes(t.slug))
  .slice(0, 6);
---

<Base
  title="Compare SaaS Tools & Pricing | StackSwitch (2026)"
  description="Compare 100+ SaaS tools on pricing, features, and ratings. Find a cheaper alternative or confirm your current software is the best pick for your team."
>

  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white border-b border-gray-100 py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">
        Find the right software.<br />
        <span class="text-indigo-600">Switch with confidence.</span>
      </h1>
      <p class="text-lg text-gray-600 mb-8">
        Compare alternatives, pricing, and features for 100+ SaaS tools. No fluff — just the data you need to make the call.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        {Object.entries(CATEGORIES).slice(0, 6).map(([slug, name]) => (
          <a href={`/category/${slug}`} class="bg-white border border-gray-200 px-4 py-2 rounded-full text-sm font-medium hover:border-indigo-300 hover:text-indigo-600 transition-colors shadow-sm flex items-center gap-2">
            <CategoryIcon category={slug} size={18} />
            {name}
          </a>
        ))}
      </div>
      <div class="mt-10">
        <HeroIllustration />
      </div>
    </div>
  </section>

  <!-- Popular tools -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold mb-2">Popular tools</h2>
    <p class="text-gray-500 mb-8">Most-searched SaaS alternatives this month</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {featured.map((tool) => (
        <div class="border border-gray-200 rounded-xl p-5 hover:border-indigo-200 transition-colors group">
          <div class="flex justify-between items-start mb-2">
            <h3 class="font-bold text-lg">{tool.name}</h3>
            <span class="text-sm text-yellow-500 font-medium">★ {tool.g2_score}</span>
          </div>
          <p class="text-gray-500 text-sm mb-4">{tool.tagline}</p>
          <div class="text-sm text-gray-600 mb-4">
            From <span class="font-semibold text-gray-900">{tool.pricing.has_free_plan ? 'Free' : formatPrice(tool.pricing.starting_price, tool.pricing.currency)}</span>
            {tool.pricing.has_free_plan && tool.pricing.starting_price > 0 && (
              <span class="text-gray-400"> · paid from {formatPrice(tool.pricing.starting_price, tool.pricing.currency)}</span>
            )}
          </div>
          <div class="flex gap-4 text-sm">
            <a href={`/alternatives/${tool.slug}`} class="text-indigo-600 font-medium hover:underline">
              Alternatives →
            </a>
            <a href={`/pricing/${tool.slug}`} class="text-gray-500 hover:text-gray-900">Pricing</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- By category -->
  <section class="bg-gray-50 border-t border-gray-100 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold mb-8">Browse by category</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {Object.entries(byCategory).map(([cat, catTools]) => (
          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <div class="flex justify-between items-center mb-3">
              <h3 class="font-semibold">{CATEGORIES[cat]}</h3>
              <span class="text-xs text-gray-400">{catTools.length} tools</span>
            </div>
            <ul class="space-y-2 mb-4">
              {catTools.slice(0, 3).map((tool) => (
                <li class="flex justify-between items-center text-sm">
                  <a href={`/tools/${tool.slug}`} class="text-gray-700 hover:text-indigo-600">{tool.name}</a>
                  <a href={`/alternatives/${tool.slug}`} class="text-xs text-indigo-500 hover:underline">alts →</a>
                </li>
              ))}
            </ul>
            <a href={`/category/${cat}`} class="text-sm text-indigo-600 font-medium hover:underline">
              See all {CATEGORIES[cat]} tools →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guides promo -->
  <section class="max-w-4xl mx-auto px-4 py-14">
    <div class="bg-indigo-50 border border-indigo-100 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold mb-3">Not sure where to start?</h2>
      <p class="text-gray-600 max-w-xl mx-auto mb-6">
        Our guides break down how to evaluate software, understand pricing models, and build a tech stack that grows with you.
      </p>
      <a href="/guides" class="inline-block bg-indigo-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
        Read the guides →
      </a>
    </div>
  </section>

  <!-- Email capture -->
  <section class="max-w-4xl mx-auto px-4 py-14">
    <div class="bg-white border border-gray-200 rounded-2xl p-8 text-center shadow-sm">
      <h2 class="text-2xl font-bold mb-3">Get free SaaS comparison reports</h2>
      <p class="text-gray-600 max-w-xl mx-auto mb-6">
        We send occasional deep-dives comparing popular tools — no spam, unsubscribe any time.
      </p>
      <div id="email-success" class="hidden text-indigo-700 font-medium py-3">
        Reports coming your way — check your inbox.
      </div>
      <form id="email-form" action="https://api.staticforms.xyz/submit" method="POST" class="flex flex-col gap-3 max-w-md mx-auto text-left">
        <input type="hidden" name="accessKey" value="sf_9e906eb6c00416b9d3354749" />
        <input type="hidden" name="redirectTo" value="https://stackswitch.co/?joined=true" />
        <input type="hidden" name="subject" value="New subscriber — StackSwitch.co" />
        <input
          type="text"
          name="name"
          placeholder="Your name"
          required
          class="border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400"
        />
        <input
          type="email"
          name="email"
          placeholder="Your email address"
          required
          class="border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400"
        />
        <button
          type="submit"
          class="bg-indigo-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors"
        >
          Send Me Reports
        </button>
      </form>
    </div>
  </section>

  <script>
    const params = new URLSearchParams(window.location.search);
    if (params.get('joined') === 'true') {
      document.getElementById('email-form')?.classList.add('hidden');
      document.getElementById('email-success')?.classList.remove('hidden');
    }
  </script>

  <!-- Trust & methodology -->
  <section class="border-t border-gray-100 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold mb-3 text-center">How we compare tools</h2>
      <p class="text-gray-600 max-w-xl mx-auto text-center mb-10">
        Every comparison follows the same rigorous process — no shortcuts, no vendor influence.
      </p>

      <!-- Methodology SVG -->
      <div class="flex justify-center mb-10">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 120" class="w-full max-w-xl" aria-hidden="true">
          <!-- Step 1: Research -->
          <rect x="8" y="10" width="170" height="100" rx="12" fill="white" stroke="#6366f1" stroke-width="1.5"/>
          <circle cx="40" cy="40" r="14" fill="#6366f1" opacity="0.1"/>
          <text x="40" y="45" text-anchor="middle" font-size="13" font-weight="700" fill="#6366f1" font-family="Inter, sans-serif">1</text>
          <text x="62" y="44" font-size="12" font-weight="600" fill="#1f2937" font-family="Inter, sans-serif">Research</text>
          <text x="24" y="68" font-size="9" fill="#6b7280" font-family="Inter, sans-serif">Official pricing and docs</text>
          <text x="24" y="82" font-size="9" fill="#6b7280" font-family="Inter, sans-serif">G2 and Capterra reviews</text>
          <text x="24" y="96" font-size="9" fill="#6b7280" font-family="Inter, sans-serif">Feature verification</text>

          <!-- Arrow 1 -->
          <line x1="188" y1="60" x2="210" y2="60" stroke="#c7d2fe" stroke-width="2"/>
          <polygon points="210,54 222,60 210,66" fill="#c7d2fe"/>

          <!-- Step 2: Compare -->
          <rect x="226" y="10" width="170" height="100" rx="12" fill="white" stroke="#6366f1" stroke-width="1.5"/>
          <circle cx="258" cy="40" r="14" fill="#6366f1" opacity="0.1"/>
          <text x="258" y="45" text-anchor="middle" font-size="13" font-weight="700" fill="#6366f1" font-family="Inter, sans-serif">2</text>
          <text x="280" y="44" font-size="12" font-weight="600" fill="#1f2937" font-family="Inter, sans-serif">Compare</text>
          <text x="242" y="68" font-size="9" fill="#6b7280" font-family="Inter, sans-serif">Side-by-side pricing</text>
          <text x="242" y="82" font-size="9" fill="#6b7280" font-family="Inter, sans-serif">Feature matching</text>
          <text x="242" y="96" font-size="9" fill="#6b7280" font-family="Inter, sans-serif">Pros and cons analysis</text>

          <!-- Arrow 2 -->
          <line x1="406" y1="60" x2="428" y2="60" stroke="#c7d2fe" stroke-width="2"/>
          <polygon points="428,54 440,60 428,66" fill="#c7d2fe"/>

          <!-- Step 3: Recommend -->
          <rect x="444" y="10" width="150" height="100" rx="12" fill="white" stroke="#6366f1" stroke-width="1.5"/>
          <circle cx="476" cy="40" r="14" fill="#6366f1" opacity="0.1"/>
          <text x="476" y="45" text-anchor="middle" font-size="13" font-weight="700" fill="#6366f1" font-family="Inter, sans-serif">3</text>
          <text x="496" y="44" font-size="10" font-weight="600" fill="#1f2937" font-family="Inter, sans-serif">Recommend</text>
          <text x="460" y="68" font-size="9" fill="#6b7280" font-family="Inter, sans-serif">Verdicts by use case</text>
          <text x="460" y="82" font-size="9" fill="#6b7280" font-family="Inter, sans-serif">Budget-based picks</text>
          <text x="460" y="96" font-size="9" fill="#6b7280" font-family="Inter, sans-serif">Clear trade-offs</text>
        </svg>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4 max-w-lg mx-auto mb-8">
        <div class="text-center">
          <div class="text-2xl font-bold text-indigo-600">85+</div>
          <div class="text-sm text-gray-500">Tools compared</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-indigo-600">22</div>
          <div class="text-sm text-gray-500">Categories</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-indigo-600">{new Date().getFullYear()}</div>
          <div class="text-sm text-gray-500">Updated</div>
        </div>
      </div>

      <div class="text-center">
        <a href="/about" class="text-sm text-indigo-600 font-medium hover:underline">
          Learn more about our methodology
        </a>
      </div>
    </div>
  </section>

</Base>
