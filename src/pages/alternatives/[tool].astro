---
import Base from '../../layouts/Base.astro';
import { getAllTools, getToolBySlug, formatPrice, type Tool } from '../../utils/tools';

export async function getStaticPaths() {
  const tools = await getAllTools();
  return tools.map((tool) => ({ params: { tool: tool.slug } }));
}

const { tool: slug } = Astro.params;
const tool = await getToolBySlug(slug);
if (!tool) return Astro.redirect('/404');

const altTools: Tool[] = (
  await Promise.all(tool.alternatives.map((s) => getToolBySlug(s)))
).filter(Boolean) as Tool[];

const year = new Date().getFullYear();
const topAlt = altTools[0];
const freeAlts = altTools.filter((a) => a.pricing.has_free_plan);
const cheapestAlt = [...altTools].sort((a, b) => a.pricing.starting_price - b.pricing.starting_price)[0];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Best ${tool.name} Alternatives ${year}`,
  "description": `The top alternatives to ${tool.name}, compared by price, features, and ratings.`,
  "numberOfItems": altTools.length,
  "itemListElement": altTools.map((alt, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": alt.name,
    "description": alt.tagline,
    "url": `https://stackswitch.co/tools/${alt.slug}`
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stackswitch.co" },
    { "@type": "ListItem", "position": 2, "name": tool.name, "item": `https://stackswitch.co/tools/${tool.slug}` },
    { "@type": "ListItem", "position": 3, "name": "Alternatives", "item": `https://stackswitch.co/alternatives/${tool.slug}` }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the best alternative to ${tool.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": topAlt
          ? `${topAlt.name} is widely considered the top alternative to ${tool.name}. It starts at ${formatPrice(topAlt.pricing.starting_price, topAlt.pricing.currency)}/mo${topAlt.pricing.has_free_plan ? ' with a free plan available' : ''} and has a G2 score of ${topAlt.g2_score}/5.`
          : `There are several strong alternatives to ${tool.name}. See the full comparison at stackswitch.co/alternatives/${tool.slug}.`
      }
    },
    {
      "@type": "Question",
      "name": `Is there a free alternative to ${tool.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": freeAlts.length > 0
          ? `Yes — ${freeAlts.slice(0, 3).map((a) => a.name).join(', ')} all offer free plans as alternatives to ${tool.name}.`
          : `Most alternatives to ${tool.name} are paid tools. Compare pricing at stackswitch.co/alternatives/${tool.slug}.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the cheapest alternative to ${tool.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": cheapestAlt
          ? cheapestAlt.pricing.has_free_plan
            ? `${cheapestAlt.name} is the cheapest option, with a free plan available. Paid plans start at ${formatPrice(cheapestAlt.pricing.starting_price, cheapestAlt.pricing.currency)}/mo.`
            : `${cheapestAlt.name} is among the most affordable alternatives at ${formatPrice(cheapestAlt.pricing.starting_price, cheapestAlt.pricing.currency)}/mo.`
          : `Pricing varies across alternatives. See the comparison table at stackswitch.co/alternatives/${tool.slug}.`
      }
    }
  ]
};
---

<Base
  title={`Best ${tool.name} Alternatives in ${year} (Free & Paid)`}
  description={`Looking for ${tool.name} alternatives? We compare the ${altTools.length}+ best options — including free plans, pricing, and who each tool is best for.`}
  schema={[itemListSchema, breadcrumbSchema, faqSchema]}
>
  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-900">Home</a>
      <span class="mx-2">/</span>
      <a href={`/tools/${tool.slug}`} class="hover:text-gray-900">{tool.name}</a>
      <span class="mx-2">/</span>
      <span>Alternatives</span>
    </nav>

    <!-- Hero -->
    <h1 class="text-3xl font-bold mb-3">Best {tool.name} Alternatives ({year})</h1>
    <p class="text-lg text-gray-600 mb-8">
      {tool.name} is {tool.tagline.toLowerCase()}, starting at {formatPrice(tool.pricing.starting_price, tool.pricing.currency)}/mo.
      Here are the best alternatives — whether you need something cheaper, simpler, or with different features.
    </p>

    <!-- Quick facts bar -->
    <div class="flex flex-wrap gap-4 mb-8 text-sm">
      <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded-full">{altTools.length} alternatives compared</span>
      {freeAlts.length > 0 && <span class="bg-green-50 text-green-700 px-3 py-1.5 rounded-full">✓ {freeAlts.length} with free plans</span>}
      {cheapestAlt && cheapestAlt.pricing.starting_price < tool.pricing.starting_price && (
        <span class="bg-blue-50 text-blue-700 px-3 py-1.5 rounded-full">Cheapest from {formatPrice(cheapestAlt.pricing.starting_price, cheapestAlt.pricing.currency)}/mo</span>
      )}
    </div>

    <!-- Why switch callout -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 mb-10">
      <h2 class="font-semibold text-amber-900 mb-2">Why people switch from {tool.name}</h2>
      <ul class="space-y-1">
        {tool.cons.map((con) => (
          <li class="text-amber-800 text-sm flex gap-2"><span>→</span><span>{con}</span></li>
        ))}
      </ul>
    </div>

    <!-- Top pick callout -->
    {topAlt && (
      <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-5 mb-8">
        <div class="text-xs font-semibold text-indigo-600 mb-1">Our top pick</div>
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <div>
            <div class="font-bold text-lg">{topAlt.name}</div>
            <p class="text-gray-600 text-sm">{topAlt.tagline}</p>
          </div>
          <div class="flex gap-3">
            <a href={`/tools/${topAlt.slug}`} class="text-sm font-medium text-indigo-600 hover:underline">See review →</a>
            <a href={`/compare/${tool.slug}-vs-${topAlt.slug}`} class="text-sm text-gray-500 hover:text-gray-900">Compare →</a>
          </div>
        </div>
      </div>
    )}

    <!-- Alternatives list -->
    <div class="space-y-6">
      {altTools.map((alt, i) => (
        <div class="border border-gray-200 rounded-xl p-6 hover:border-indigo-200 transition-colors">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-3">
            <div>
              <span class="text-xs font-medium text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-full mb-2 inline-block">#{i + 1} Alternative</span>
              <h2 class="text-xl font-bold">{alt.name}</h2>
              <p class="text-gray-500 text-sm">{alt.tagline}</p>
            </div>
            <div class="text-right">
              <div class="text-sm text-gray-500">Starting at</div>
              <div class="font-bold text-lg">
                {alt.pricing.has_free_plan ? 'Free' : formatPrice(alt.pricing.starting_price, alt.pricing.currency)}
              </div>
              {alt.pricing.has_free_plan && alt.pricing.starting_price > 0 && (
                <div class="text-xs text-gray-400">Paid from {formatPrice(alt.pricing.starting_price, alt.pricing.currency)}</div>
              )}
            </div>
          </div>
          <p class="text-gray-700 text-sm mb-4">{alt.description}</p>
          <div class="flex flex-wrap gap-2 mb-4">
            {alt.pros.slice(0, 3).map((pro) => (
              <span class="text-xs bg-green-50 text-green-700 px-2 py-1 rounded-full">✓ {pro}</span>
            ))}
          </div>
          <div class="flex gap-3 flex-wrap">
            <a href={`/compare/${tool.slug}-vs-${alt.slug}`} class="text-sm font-medium text-indigo-600 hover:underline">
              {tool.name} vs {alt.name} →
            </a>
            <a href={`/pricing/${alt.slug}`} class="text-sm text-gray-500 hover:text-gray-900">
              See {alt.name} pricing →
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Comparison table -->
    {altTools.length > 0 && (
      <div class="mt-12">
        <h2 class="text-2xl font-bold mb-6">{tool.name} vs alternatives: quick comparison</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-200">
                <th class="text-left p-3 font-semibold">Tool</th>
                <th class="text-left p-3 font-semibold">Starting price</th>
                <th class="text-left p-3 font-semibold">Free plan</th>
                <th class="text-left p-3 font-semibold">Pricing model</th>
                <th class="text-left p-3 font-semibold">G2 score</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-100 bg-indigo-50">
                <td class="p-3 font-semibold">{tool.name} <span class="text-xs text-indigo-600">(current)</span></td>
                <td class="p-3">{formatPrice(tool.pricing.starting_price, tool.pricing.currency)}</td>
                <td class="p-3">{tool.pricing.has_free_plan ? '✓' : '✗'}</td>
                <td class="p-3 capitalize">{tool.pricing.model}</td>
                <td class="p-3">{tool.g2_score}/5</td>
              </tr>
              {altTools.map((alt) => (
                <tr class="border-b border-gray-100 hover:bg-gray-50">
                  <td class="p-3"><a href={`/tools/${alt.slug}`} class="font-medium text-indigo-600 hover:underline">{alt.name}</a></td>
                  <td class="p-3">{formatPrice(alt.pricing.starting_price, alt.pricing.currency)}</td>
                  <td class="p-3">{alt.pricing.has_free_plan ? '✓' : '✗'}</td>
                  <td class="p-3 capitalize">{alt.pricing.model}</td>
                  <td class="p-3">{alt.g2_score}/5</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    <!-- Verdict -->
    {topAlt && (
      <div class="mt-10 border-l-4 border-indigo-400 pl-5 py-1">
        <h2 class="font-bold mb-1">Our verdict</h2>
        <p class="text-gray-700 text-sm leading-relaxed">
          If you are switching from {tool.name}, {topAlt.name} is our top pick — {topAlt.tagline.toLowerCase()}, with a G2 score of {topAlt.g2_score}/5.
          {freeAlts.length > 0 ? ` For a free option, ${freeAlts[0].name} is worth considering.` : ''}
          Use the comparison links above to do a side-by-side before committing.
        </p>
      </div>
    )}

    <!-- FAQ -->
    <div class="mt-12">
      <h2 class="text-xl font-bold mb-5">{tool.name} alternatives: frequently asked questions</h2>
      <div class="space-y-4">
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">What is the best alternative to {tool.name}?</summary>
          <p class="text-gray-600 text-sm mt-3">
            {topAlt
              ? `${topAlt.name} is our top-ranked alternative. It starts at ${formatPrice(topAlt.pricing.starting_price, topAlt.pricing.currency)}/mo${topAlt.pricing.has_free_plan ? ' with a free plan' : ''} and scores ${topAlt.g2_score}/5 on G2.`
              : `See the ranked list above for the best-rated alternatives to ${tool.name}.`}
          </p>
        </details>
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">Is there a free alternative to {tool.name}?</summary>
          <p class="text-gray-600 text-sm mt-3">
            {freeAlts.length > 0
              ? `Yes — ${freeAlts.slice(0, 3).map((a) => a.name).join(', ')} all offer free plans.`
              : `Most alternatives to ${tool.name} are paid. See pricing details in the comparison table above.`}
          </p>
        </details>
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">What is the cheapest alternative to {tool.name}?</summary>
          <p class="text-gray-600 text-sm mt-3">
            {cheapestAlt
              ? cheapestAlt.pricing.has_free_plan
                ? `${cheapestAlt.name} offers the lowest entry point with a free plan. Paid plans start at ${formatPrice(cheapestAlt.pricing.starting_price, cheapestAlt.pricing.currency)}/mo.`
                : `${cheapestAlt.name} is among the most affordable at ${formatPrice(cheapestAlt.pricing.starting_price, cheapestAlt.pricing.currency)}/mo.`
              : `See the comparison table above for a full pricing breakdown.`}
          </p>
        </details>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-12 bg-indigo-50 rounded-xl p-6 text-center">
      <h3 class="font-bold text-lg mb-2">Not sure which tool to pick?</h3>
      <p class="text-gray-600 text-sm mb-4">See a detailed breakdown of {tool.name} pricing before you decide.</p>
      <a href={`/pricing/${tool.slug}`} class="inline-block bg-indigo-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
        See {tool.name} pricing →
      </a>
    </div>

  </div>
</Base>
