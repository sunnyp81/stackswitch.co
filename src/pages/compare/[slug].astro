---
import Base from '../../layouts/Base.astro';
import { getAllTools, getToolBySlug, formatPrice, type Tool } from '../../utils/tools';
import CompareVisual from '../../components/svg/CompareVisual.astro';

export async function getStaticPaths() {
  const tools = await getAllTools();
  const paths: { params: { slug: string } }[] = [];

  for (const tool of tools) {
    for (const altSlug of tool.alternatives) {
      paths.push({ params: { slug: `${tool.slug}-vs-${altSlug}` } });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const [aSlug, bSlug] = slug.split('-vs-');
const [toolA, toolB] = await Promise.all([
  getToolBySlug(aSlug),
  getToolBySlug(bSlug),
]);

if (!toolA || !toolB) return Astro.redirect('/404');

const year = new Date().getFullYear();

function winner(a: number, b: number): 'a' | 'b' | 'tie' {
  if (a > b) return 'a';
  if (b > a) return 'b';
  return 'tie';
}

const priceWinner = winner(toolB.pricing.starting_price, toolA.pricing.starting_price); // lower is better
const g2Winner = winner(toolA.g2_score, toolB.g2_score);

const cheaperTool = priceWinner === 'a' ? toolA : priceWinner === 'b' ? toolB : null;
const higherRatedTool = g2Winner === 'a' ? toolA : g2Winner === 'b' ? toolB : null;

const chooseAItems: string[] = toolA.use_cases && toolA.use_cases.length > 0
  ? toolA.use_cases.slice(0, 3)
  : [
      toolA.pros[0] ?? toolA.features[0] ?? 'strong feature set',
      toolA.pros[1] ?? toolA.features[1] ?? 'reliable performance',
      ...(toolA.pricing.has_free_plan ? ['you want a free plan to start with'] : []),
    ];
const chooseBItems: string[] = toolB.use_cases && toolB.use_cases.length > 0
  ? toolB.use_cases.slice(0, 3)
  : [
      toolB.pros[0] ?? toolB.features[0] ?? 'strong feature set',
      toolB.pros[1] ?? toolB.features[1] ?? 'reliable performance',
      ...(toolB.pricing.has_free_plan ? ['you want a free plan to start with'] : []),
    ];

// Smarter verdict
const ratingDiff = toolA.g2_score - toolB.g2_score;
let verdictText = '';
if (Math.abs(ratingDiff) >= 0.2) {
  const better = ratingDiff > 0 ? toolA : toolB;
  const lower = ratingDiff > 0 ? toolB : toolA;
  verdictText += `${better.name} scores higher on G2 (${better.g2_score}/5 vs ${lower.g2_score}/5), suggesting stronger overall user satisfaction. `;
} else {
  verdictText += `${toolA.name} and ${toolB.name} are closely matched on user ratings. `;
}
if (cheaperTool) {
  verdictText += `${cheaperTool.name} is the more affordable option. `;
}
if (toolA.pricing.has_free_plan !== toolB.pricing.has_free_plan) {
  const withFree = toolA.pricing.has_free_plan ? toolA : toolB;
  verdictText += `${withFree.name} offers a free plan — a lower-risk way to test before committing. `;
}
verdictText += `The right pick depends on your team size and workflow.`;

// Related comparisons
const relatedAltASlugs = toolA.alternatives.filter(s => s !== bSlug).slice(0, 3);
const relatedAltBSlugs = toolB.alternatives.filter(s => s !== aSlug).slice(0, 3);
const allRelatedSlugs = [...new Set([...relatedAltASlugs, ...relatedAltBSlugs])].slice(0, 6);
const relatedToolLookup: Record<string, Tool> = {};
for (const t of (await Promise.all(allRelatedSlugs.map(s => getToolBySlug(s)))).filter((t): t is Tool => t !== null)) {
  relatedToolLookup[t.slug] = t;
}
const relatedComparisons = [
  ...relatedAltASlugs.filter(s => relatedToolLookup[s]).map(s => ({ slug: `${aSlug}-vs-${s}`, label: `${toolA.name} vs ${relatedToolLookup[s].name}` })),
  ...relatedAltBSlugs.filter(s => relatedToolLookup[s]).map(s => ({ slug: `${bSlug}-vs-${s}`, label: `${toolB.name} vs ${relatedToolLookup[s].name}` })),
].slice(0, 5);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Is ${toolA.name} better than ${toolB.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": g2Winner === 'a'
          ? `${toolA.name} has a higher G2 score (${toolA.g2_score}/5 vs ${toolB.g2_score}/5), suggesting stronger user satisfaction. However, the best choice depends on your specific use case and budget.`
          : g2Winner === 'b'
          ? `${toolB.name} has a higher G2 score (${toolB.g2_score}/5 vs ${toolA.g2_score}/5). That said, the right tool depends on your team's needs.`
          : `${toolA.name} and ${toolB.name} have similar G2 ratings. The best option depends on your budget and feature priorities.`
      }
    },
    {
      "@type": "Question",
      "name": `Which is cheaper, ${toolA.name} or ${toolB.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": cheaperTool
          ? `${cheaperTool.name} is cheaper, starting at ${formatPrice(cheaperTool.pricing.starting_price, cheaperTool.pricing.currency)}/mo compared to ${formatPrice((cheaperTool === toolA ? toolB : toolA).pricing.starting_price, (cheaperTool === toolA ? toolB : toolA).pricing.currency)}/mo.`
          : `${toolA.name} and ${toolB.name} start at the same price: ${formatPrice(toolA.pricing.starting_price, toolA.pricing.currency)}/mo.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the difference between ${toolA.name} and ${toolB.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${toolA.name} focuses on ${toolA.features.slice(0, 3).join(', ').toLowerCase()}. ${toolB.name} focuses on ${toolB.features.slice(0, 3).join(', ').toLowerCase()}. Both serve similar use cases but differ in pricing model, feature depth, and target audience.`
      }
    },
    {
      "@type": "Question",
      "name": `Can I migrate from ${toolA.name} to ${toolB.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Most teams migrate between ${toolA.name} and ${toolB.name} within a day or two. Export your data from ${toolA.name} (typically as CSV or via API), then use ${toolB.name}'s import wizard to bring it across. Check each tool's help centre for a step-by-step migration guide before switching.`
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stackswitch.co" },
    { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://stackswitch.co" },
    { "@type": "ListItem", "position": 3, "name": `${toolA.name} vs ${toolB.name}`, "item": `https://stackswitch.co/compare/${slug}` }
  ]
};
---

<Base
  title={`${toolA.name} vs ${toolB.name} (${year}): Full Breakdown`}
  description={`${toolA.name} vs ${toolB.name}: side-by-side pricing, features, and user ratings for ${year}. See which wins on value, ease of use, and support.`}
  schema={[faqSchema, breadcrumbSchema]}
>
  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-900">Home</a>
      <span class="mx-2">/</span>
      <span>Compare</span>
      <span class="mx-2">/</span>
      <span>{toolA.name} vs {toolB.name}</span>
    </nav>

    <h1 class="text-3xl font-bold mb-3">{toolA.name} vs {toolB.name}: Which is better in {year}?</h1>
    <p class="text-lg text-gray-600 mb-6">
      A side-by-side comparison of pricing, features, and use cases to help you decide between {toolA.name} and {toolB.name}.
    </p>
    <div class="mb-10">
      <CompareVisual />
    </div>

    <!-- Quick verdict -->
    <div class="grid md:grid-cols-2 gap-4 mb-10">
      <div class="border border-indigo-200 rounded-xl p-5">
        <div class="text-xs font-semibold text-indigo-600 mb-1">{toolA.name}</div>
        <p class="text-sm text-gray-600 mb-3">{toolA.tagline}</p>
        <div class="text-sm font-medium">From {formatPrice(toolA.pricing.starting_price, toolA.pricing.currency)}/mo</div>
        <div class="text-sm text-gray-500">{toolA.pricing.has_free_plan ? 'Free plan available' : 'No free plan'}</div>
      </div>
      <div class="border border-gray-200 rounded-xl p-5">
        <div class="text-xs font-semibold text-gray-500 mb-1">{toolB.name}</div>
        <p class="text-sm text-gray-600 mb-3">{toolB.tagline}</p>
        <div class="text-sm font-medium">From {formatPrice(toolB.pricing.starting_price, toolB.pricing.currency)}/mo</div>
        <div class="text-sm text-gray-500">{toolB.pricing.has_free_plan ? 'Free plan available' : 'No free plan'}</div>
      </div>
    </div>

    <!-- Comparison table -->
    <h2 class="text-xl font-bold mb-4">Head-to-head comparison</h2>
    <div class="overflow-x-auto mb-10">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b-2 border-gray-200">
            <th class="text-left p-3 w-1/3">Feature</th>
            <th class="text-left p-3 w-1/3 text-indigo-600">{toolA.name}</th>
            <th class="text-left p-3 w-1/3">{toolB.name}</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-gray-100">
            <td class="p-3 font-medium text-gray-600">Starting price</td>
            <td class={`p-3 font-semibold ${priceWinner === 'a' ? 'text-green-600' : ''}`}>
              {formatPrice(toolA.pricing.starting_price, toolA.pricing.currency)}/mo
              {priceWinner === 'a' && <span class="text-xs ml-1">✓ Cheaper</span>}
            </td>
            <td class={`p-3 font-semibold ${priceWinner === 'b' ? 'text-green-600' : ''}`}>
              {formatPrice(toolB.pricing.starting_price, toolB.pricing.currency)}/mo
              {priceWinner === 'b' && <span class="text-xs ml-1">✓ Cheaper</span>}
            </td>
          </tr>
          <tr class="border-b border-gray-100 bg-gray-50">
            <td class="p-3 font-medium text-gray-600">Free plan</td>
            <td class="p-3">{toolA.pricing.has_free_plan ? '✓ Yes' : '✗ No'}</td>
            <td class="p-3">{toolB.pricing.has_free_plan ? '✓ Yes' : '✗ No'}</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="p-3 font-medium text-gray-600">Pricing model</td>
            <td class="p-3 capitalize">{toolA.pricing.model}</td>
            <td class="p-3 capitalize">{toolB.pricing.model}</td>
          </tr>
          <tr class="border-b border-gray-100 bg-gray-50">
            <td class="p-3 font-medium text-gray-600">G2 rating</td>
            <td class={`p-3 font-semibold ${g2Winner === 'a' ? 'text-green-600' : ''}`}>
              {toolA.g2_score}/5 {g2Winner === 'a' && '↑'}
            </td>
            <td class={`p-3 font-semibold ${g2Winner === 'b' ? 'text-green-600' : ''}`}>
              {toolB.g2_score}/5 {g2Winner === 'b' && '↑'}
            </td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="p-3 font-medium text-gray-600">Capterra rating</td>
            <td class="p-3">{toolA.capterra_score}/5</td>
            <td class="p-3">{toolB.capterra_score}/5</td>
          </tr>
          <tr class="border-b border-gray-100 bg-gray-50">
            <td class="p-3 font-medium text-gray-600">Founded</td>
            <td class="p-3">{toolA.founded}</td>
            <td class="p-3">{toolB.founded}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Pros/cons -->
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      {[toolA, toolB].map((tool) => (
        <div>
          <h3 class="font-bold text-lg mb-3">{tool.name}: pros & cons</h3>
          <div class="space-y-4">
            <div>
              <div class="text-sm font-semibold text-green-700 mb-2">Pros</div>
              <ul class="space-y-1">
                {tool.pros.map((p) => <li class="text-sm flex gap-2 text-gray-700"><span class="text-green-500">✓</span>{p}</li>)}
              </ul>
            </div>
            <div>
              <div class="text-sm font-semibold text-red-700 mb-2">Cons</div>
              <ul class="space-y-1">
                {tool.cons.map((c) => <li class="text-sm flex gap-2 text-gray-700"><span class="text-red-400">✗</span>{c}</li>)}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Who should choose which -->
    <div class="grid md:grid-cols-2 gap-4 mb-12">
      <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-5">
        <h3 class="font-bold mb-3">Choose {toolA.name} if...</h3>
        <ul class="space-y-2 mb-3">
          {chooseAItems.map(item => (
            <li class="text-sm text-gray-700 flex gap-2"><span class="text-indigo-500 shrink-0 mt-0.5">→</span>{item}</li>
          ))}
        </ul>
        <a href={`/tools/${toolA.slug}`} class="text-sm text-indigo-600 hover:underline inline-block">Read {toolA.name} review →</a>
      </div>
      <div class="bg-gray-50 border border-gray-100 rounded-xl p-5">
        <h3 class="font-bold mb-3">Choose {toolB.name} if...</h3>
        <ul class="space-y-2 mb-3">
          {chooseBItems.map(item => (
            <li class="text-sm text-gray-700 flex gap-2"><span class="text-gray-400 shrink-0 mt-0.5">→</span>{item}</li>
          ))}
        </ul>
        <a href={`/tools/${toolB.slug}`} class="text-sm text-indigo-600 hover:underline inline-block">Read {toolB.name} review →</a>
      </div>
    </div>

    <!-- Verdict -->
    <div class="border-l-4 border-indigo-400 pl-5 py-1 mb-12">
      <h2 class="font-bold mb-1">Our verdict</h2>
      <p class="text-gray-700 text-sm leading-relaxed">{verdictText}</p>
    </div>

    <!-- FAQ -->
    <div class="mb-12">
      <h2 class="text-xl font-bold mb-5">{toolA.name} vs {toolB.name}: frequently asked questions</h2>
      <div class="space-y-4">
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">Is {toolA.name} better than {toolB.name}?</summary>
          <p class="text-gray-600 text-sm mt-3">
            {g2Winner === 'a'
              ? `${toolA.name} has a higher G2 score (${toolA.g2_score}/5 vs ${toolB.g2_score}/5).`
              : g2Winner === 'b'
              ? `${toolB.name} has a higher G2 score (${toolB.g2_score}/5 vs ${toolA.g2_score}/5).`
              : `Both tools have similar G2 ratings.`}
            {' '}The best tool depends on your specific use case and budget.
          </p>
        </details>
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">Which is cheaper, {toolA.name} or {toolB.name}?</summary>
          <p class="text-gray-600 text-sm mt-3">
            {cheaperTool
              ? `${cheaperTool.name} is cheaper, starting at ${formatPrice(cheaperTool.pricing.starting_price, cheaperTool.pricing.currency)}/mo.`
              : `Both start at ${formatPrice(toolA.pricing.starting_price, toolA.pricing.currency)}/mo.`}
          </p>
        </details>
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">What is the main difference between {toolA.name} and {toolB.name}?</summary>
          <p class="text-gray-600 text-sm mt-3">
            {toolA.name} focuses on {toolA.features.slice(0, 3).join(', ').toLowerCase()}.
            {toolB.name} focuses on {toolB.features.slice(0, 3).join(', ').toLowerCase()}.
            Both serve similar use cases but differ in approach and pricing model.
          </p>
        </details>
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">Can I migrate from {toolA.name} to {toolB.name}?</summary>
          <p class="text-gray-600 text-sm mt-3">
            Most teams migrate between {toolA.name} and {toolB.name} within a day or two. Export your data from {toolA.name} (typically as CSV or via API), then use {toolB.name}'s import wizard to bring it across. Check each tool's help centre for a step-by-step migration guide before switching.
          </p>
        </details>
      </div>
    </div>

    <!-- CTAs -->
    <div class="grid md:grid-cols-2 gap-4 mb-10">
      <a href={`/alternatives/${toolA.slug}`} class="border border-gray-200 rounded-xl p-4 hover:border-indigo-200 transition-colors text-center">
        <div class="font-semibold mb-1">More {toolA.name} alternatives</div>
        <div class="text-sm text-indigo-600">See all options →</div>
      </a>
      <a href={`/alternatives/${toolB.slug}`} class="border border-gray-200 rounded-xl p-4 hover:border-indigo-200 transition-colors text-center">
        <div class="font-semibold mb-1">More {toolB.name} alternatives</div>
        <div class="text-sm text-indigo-600">See all options →</div>
      </a>
    </div>

    <!-- Related comparisons -->
    {relatedComparisons.length > 0 && (
      <div class="border-t border-gray-100 pt-8">
        <h2 class="text-base font-semibold mb-4 text-gray-700">Related comparisons</h2>
        <div class="flex flex-wrap gap-2">
          {relatedComparisons.map(c => (
            <a href={`/compare/${c.slug}`} class="text-sm border border-gray-200 rounded-lg px-3 py-1.5 hover:border-indigo-300 hover:text-indigo-600 transition-colors">
              {c.label}
            </a>
          ))}
          <a href={`/category/${toolA.category}`} class="text-sm border border-gray-200 rounded-lg px-3 py-1.5 hover:border-indigo-300 hover:text-indigo-600 transition-colors">
            All {toolA.category.replace(/-/g, ' ')} tools →
          </a>
        </div>
      </div>
    )}

  </div>
</Base>
