---
import Base from '../../layouts/Base.astro';
import GuidesHero from '../../components/svg/GuidesHero.astro';

const year = new Date().getFullYear();

const guides = [
  {
    title: 'How to choose the right SaaS tool',
    slug: 'how-to-choose-saas-tools',
    description: 'A practical framework for evaluating software without drowning in feature comparison spreadsheets.',
    tag: 'Framework'
  },
  {
    title: 'SaaS pricing models explained',
    slug: 'saas-pricing-models-explained',
    description: 'Per-seat vs usage-based vs flat-rate: what each model actually means for your budget.',
    tag: 'Pricing'
  },
  {
    title: 'Building your tech stack',
    slug: 'building-your-tech-stack',
    description: 'What you need at each stage: solo, startup, scale-up, and enterprise.',
    tag: 'Strategy'
  },
  {
    title: 'Switching SaaS tools without the chaos',
    slug: 'switching-saas-tools',
    description: 'Migration checklist, data portability red flags, and how to time the switch.',
    tag: 'Operations'
  },
  {
    title: 'Free SaaS tools that are actually worth using',
    slug: 'free-saas-tools-worth-using',
    description: 'Curated list of genuinely useful free tiers — not just marketing bait.',
    tag: 'Curated'
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stackswitch.co" },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://stackswitch.co/guides" }
  ]
};
---

<Base
  title={`SaaS Guides: How to Choose, Compare & Switch Software (${year})`}
  description="Practical guides for choosing SaaS tools, understanding pricing models, building tech stacks, and switching software. Written for business buyers, not vendors."
  schema={[breadcrumbSchema]}
>
  <div class="max-w-4xl mx-auto px-4 py-12">

    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-900">Home</a>
      <span class="mx-2">/</span>
      <span>Guides</span>
    </nav>

    <h1 class="text-3xl font-bold mb-3">SaaS buying guides</h1>
    <p class="text-lg text-gray-600 mb-6">
      Practical advice for choosing, comparing, and switching software. No vendor spin — just the framework you need to make good decisions.
    </p>

    <GuidesHero class="mb-10" />

    <div class="space-y-4">
      {guides.map((guide) => (
        <a href={`/guides/${guide.slug}`} class="block border border-gray-200 rounded-xl p-6 hover:border-indigo-200 hover:bg-indigo-50/30 transition-colors group">
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class="text-xs font-semibold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-full mb-2 inline-block">{guide.tag}</span>
              <h2 class="font-bold text-lg group-hover:text-indigo-600 transition-colors">{guide.title}</h2>
              <p class="text-gray-500 text-sm mt-1">{guide.description}</p>
            </div>
            <span class="text-indigo-400 text-xl mt-4 flex-shrink-0 group-hover:translate-x-1 transition-transform">&rarr;</span>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 bg-gray-50 rounded-xl p-8 text-center">
      <h2 class="font-bold text-lg mb-2">Ready to compare tools?</h2>
      <p class="text-gray-600 text-sm mb-4">Browse our directory of 85+ SaaS tools with real pricing and user ratings.</p>
      <a href="/" class="inline-block bg-indigo-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
        Browse all tools →
      </a>
    </div>

  </div>
</Base>
