---
import Base from '../../layouts/Base.astro';
import { getAllTools, getToolBySlug, formatPrice } from '../../utils/tools';
import PricingTiers from '../../components/svg/PricingTiers.astro';

export async function getStaticPaths() {
  const tools = await getAllTools();
  return tools.map((tool) => ({ params: { tool: tool.slug } }));
}

const { tool: slug } = Astro.params;
const tool = await getToolBySlug(slug);
if (!tool) return Astro.redirect('/404');

const year = new Date().getFullYear();
const lastUpdated = new Date().toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
const currencySymbol = tool.pricing.currency === 'USD' ? '$' : '£';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": tool.name,
  "description": tool.description,
  "url": tool.website,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": tool.g2_score,
    "bestRating": 5,
    "worstRating": 1,
    "ratingCount": tool.review_count ?? 500
  },
  "offers": tool.pricing.tiers.map((tier) => ({
    "@type": "Offer",
    "name": tier.name,
    "price": tier.price,
    "priceCurrency": tool.pricing.currency,
    "description": tier.features.join(', ')
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stackswitch.co" },
    { "@type": "ListItem", "position": 2, "name": tool.name, "item": `https://stackswitch.co/tools/${tool.slug}` },
    { "@type": "ListItem", "position": 3, "name": "Pricing", "item": `https://stackswitch.co/pricing/${tool.slug}` }
  ]
};

const genericFaqs = [
  {
    "@type": "Question",
    "name": `How much does ${tool.name} cost per month?`,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": tool.pricing.has_free_plan
        ? `${tool.name} has a free plan. Paid plans start at ${formatPrice(tool.pricing.starting_price, tool.pricing.currency)}/mo.`
        : `${tool.name} starts at ${formatPrice(tool.pricing.starting_price, tool.pricing.currency)}/mo. There is no free plan.`
    }
  },
  {
    "@type": "Question",
    "name": `Does ${tool.name} have a free plan?`,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": tool.pricing.has_free_plan
        ? `Yes, ${tool.name} offers a free plan with no credit card required. Upgrading unlocks additional features.`
        : `No, ${tool.name} does not offer a free plan. You can view all paid plans above.`
    }
  },
  {
    "@type": "Question",
    "name": `How many pricing plans does ${tool.name} have?`,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": `${tool.name} offers ${tool.pricing.tiers.length} pricing plans: ${tool.pricing.tiers.map((t) => t.name).join(', ')}.`
    }
  }
];

const extraFaqSchemas = (tool.extra_faqs ?? []).map((faq) => ({
  "@type": "Question",
  "name": faq.q,
  "acceptedAnswer": { "@type": "Answer", "text": faq.a }
}));

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [...extraFaqSchemas, ...genericFaqs]
};
---

<Base
  title={`${tool.name} Pricing ${year}: True Cost & All Plans`}
  description={`${tool.name} pricing starts at ${formatPrice(tool.pricing.starting_price, tool.pricing.currency)}/mo — but the real cost is often higher. We break down all ${tool.pricing.tiers.length} plans, add-on fees, and what's actually included.`}
  schema={[productSchema, breadcrumbSchema, faqSchema]}
>
  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-900">Home</a>
      <span class="mx-2">/</span>
      <a href={`/tools/${tool.slug}`} class="hover:text-gray-900">{tool.name}</a>
      <span class="mx-2">/</span>
      <span>Pricing</span>
    </nav>

    <!-- Hero -->
    <h1 class="text-3xl font-bold mb-3">{tool.name} Pricing ({year})</h1>
    <p class="text-lg text-gray-600 mb-2">{tool.tagline}.</p>
    <div class="flex flex-wrap gap-3 mb-4">
      <span class="bg-gray-100 text-gray-700 text-sm px-3 py-1 rounded-full">
        {tool.pricing.has_free_plan ? '✓ Free plan available' : '✗ No free plan'}
      </span>
      <span class="bg-gray-100 text-gray-700 text-sm px-3 py-1 rounded-full capitalize">
        {tool.pricing.model}
      </span>
      <span class="bg-gray-100 text-gray-700 text-sm px-3 py-1 rounded-full">
        From {formatPrice(tool.pricing.starting_price, tool.pricing.currency)}/mo
      </span>
    </div>

    <!-- Author byline -->
    <div class="flex items-center gap-2 text-xs text-gray-400 mb-8 border-b border-gray-100 pb-5">
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <span>Reviewed by the <strong class="text-gray-600">StackSwitch Editorial Team</strong></span>
      <span>·</span>
      <span>Last updated {lastUpdated}</span>
    </div>

    <!-- Pricing visual -->
    <div class="mb-8">
      <PricingTiers />
    </div>

    <!-- Pricing tiers -->
    <h2 class="text-xl font-bold mb-4">{tool.name} plans</h2>
    <div class="grid md:grid-cols-2 gap-4 mb-12">
      {tool.pricing.tiers.map((tier, i) => (
        <div class={`border rounded-xl p-5 ${i === 1 ? 'border-indigo-300 bg-indigo-50' : 'border-gray-200'}`}>
          {i === 1 && <div class="text-xs font-semibold text-indigo-600 mb-2">Most popular</div>}
          <div class="flex justify-between items-start mb-3">
            <div>
              <div class="font-bold text-lg">{tier.name}</div>
              <div class="text-gray-500 text-sm capitalize">{tier.period}</div>
            </div>
            <div class="text-right">
              <div class="text-2xl font-bold">
                {tier.price === 0 ? 'Free' : `${currencySymbol}${tier.price}`}
              </div>
            </div>
          </div>
          <ul class="space-y-1.5">
            {tier.features.map((feature) => (
              <li class="text-sm text-gray-700 flex gap-2">
                <span class="text-green-500 flex-shrink-0">✓</span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Which plan is right for you? -->
    {tool.plan_guidance && tool.plan_guidance.length > 0 && (
      <div class="mb-10">
        <h2 class="text-xl font-bold mb-5">Which {tool.name} plan is right for you?</h2>
        <div class="space-y-4">
          {tool.plan_guidance.map((guidance) => (
            <div class="border border-gray-200 rounded-xl p-5">
              <div class="font-semibold text-gray-800 mb-2">{guidance.tier} plan</div>
              <p class="text-sm text-gray-700 mb-2"><strong>Best for:</strong> {guidance.best_for}</p>
              <p class="text-xs text-gray-500"><strong>Upgrade when:</strong> {guidance.upgrade_when}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- True cost: hidden costs -->
    {tool.hidden_costs && tool.hidden_costs.length > 0 && (
      <div class="mb-10 bg-amber-50 border border-amber-200 rounded-xl p-6">
        <h2 class="text-xl font-bold mb-2">The true cost: what's not in the price</h2>
        <p class="text-sm text-gray-600 mb-4">The headline price rarely tells the full story. Here's what can add to your actual bill with {tool.name}:</p>
        <ul class="space-y-3">
          {tool.hidden_costs.map((cost) => (
            <li class="text-sm text-gray-700 flex gap-3">
              <span class="text-amber-500 flex-shrink-0 mt-0.5">▲</span>
              <span>{cost}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Is it worth it? -->
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-4">Is {tool.name} worth the price?</h2>
      <p class="text-gray-600 text-sm mb-5 leading-relaxed">
        {tool.name} scores {tool.g2_score}/5 on G2 and {tool.capterra_score}/5 on Capterra.
        {tool.pricing.has_free_plan
          ? ` The free plan is a low-risk way to test it before committing to a paid tier.`
          : ` With no free plan, we recommend trialling a competitor first to validate the use case before purchasing.`}
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold text-green-700 mb-2">Pros</h3>
          <ul class="space-y-2">
            {tool.pros.map((pro) => (
              <li class="text-sm text-gray-700 flex gap-2"><span class="text-green-500">✓</span>{pro}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-red-700 mb-2">Cons</h3>
          <ul class="space-y-2">
            {tool.cons.map((con) => (
              <li class="text-sm text-gray-700 flex gap-2"><span class="text-red-400">✗</span>{con}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Ratings -->
    <div class="bg-gray-50 rounded-xl p-5 mb-10">
      <h2 class="font-semibold mb-3">{tool.name} user ratings</h2>
      <div class="grid grid-cols-2 gap-4">
        <div class="text-center">
          <div class="text-3xl font-bold text-indigo-600">{tool.g2_score}/5</div>
          <div class="text-sm text-gray-500 mt-1">G2 score</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-indigo-600">{tool.capterra_score}/5</div>
          <div class="text-sm text-gray-500 mt-1">Capterra score</div>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-5">{tool.name} pricing: frequently asked questions</h2>
      <div class="space-y-4">

        <!-- Tool-specific FAQs first -->
        {(tool.extra_faqs ?? []).map((faq) => (
          <details class="border border-gray-200 rounded-xl p-4">
            <summary class="font-medium cursor-pointer text-sm">{faq.q}</summary>
            <p class="text-gray-600 text-sm mt-3 leading-relaxed">{faq.a}</p>
          </details>
        ))}

        <!-- Generic FAQs -->
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">How much does {tool.name} cost per month?</summary>
          <p class="text-gray-600 text-sm mt-3">
            {tool.pricing.has_free_plan
              ? `${tool.name} has a free plan. Paid plans start at ${formatPrice(tool.pricing.starting_price, tool.pricing.currency)}/mo.`
              : `${tool.name} starts at ${formatPrice(tool.pricing.starting_price, tool.pricing.currency)}/mo with no free plan.`}
          </p>
        </details>
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">Does {tool.name} have a free plan?</summary>
          <p class="text-gray-600 text-sm mt-3">
            {tool.pricing.has_free_plan
              ? `Yes — ${tool.name} offers a free plan. You can upgrade to a paid tier when you need more features.`
              : `No — ${tool.name} does not have a free plan. See the plans above for pricing details.`}
          </p>
        </details>
        <details class="border border-gray-200 rounded-xl p-4">
          <summary class="font-medium cursor-pointer text-sm">How many pricing plans does {tool.name} have?</summary>
          <p class="text-gray-600 text-sm mt-3">
            {tool.name} offers {tool.pricing.tiers.length} plans: {tool.pricing.tiers.map((t) => t.name).join(', ')}.
          </p>
        </details>
      </div>
    </div>

    <!-- CTA -->
    <div class="bg-indigo-50 rounded-xl p-6 text-center">
      <h3 class="font-bold text-lg mb-2">Looking for a cheaper alternative to {tool.name}?</h3>
      <p class="text-gray-600 text-sm mb-4">We have compared the best {tool.name} alternatives by price, features, and use case.</p>
      <a href={`/alternatives/${tool.slug}`} class="inline-block bg-indigo-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
        See {tool.name} alternatives →
      </a>
    </div>

  </div>
</Base>
