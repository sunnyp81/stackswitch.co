---
/**
 * Pricing models comparison visual — per-seat, usage, flat-rate
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 180" class={`w-full max-w-md mx-auto ${className}`} aria-hidden="true">
  <defs>
    <linearGradient id="pm-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#6366f1" stop-opacity="0.08"/>
      <stop offset="100%" stop-color="#6366f1" stop-opacity="0.02"/>
    </linearGradient>
  </defs>

  <!-- Per-seat model -->
  <rect x="20" y="20" width="106" height="140" rx="10" fill="white" stroke="#c7d2fe" stroke-width="1.5"/>
  <rect x="20" y="20" width="106" height="32" rx="10" fill="url(#pm-grad)"/>
  <rect x="20" y="42" width="106" height="10" fill="url(#pm-grad)"/>
  <text x="73" y="42" text-anchor="middle" font-size="10" fill="#6366f1" font-family="Inter, sans-serif" font-weight="600">Per-seat</text>
  <!-- People icons -->
  <circle cx="46" cy="76" r="8" fill="#818cf8" opacity="0.15"/>
  <circle cx="46" cy="73" r="3" fill="#6366f1" opacity="0.4"/>
  <path d="M40 82a6 6 0 0112 0" fill="#6366f1" opacity="0.2"/>
  <circle cx="73" cy="76" r="8" fill="#818cf8" opacity="0.15"/>
  <circle cx="73" cy="73" r="3" fill="#6366f1" opacity="0.4"/>
  <path d="M67 82a6 6 0 0112 0" fill="#6366f1" opacity="0.2"/>
  <circle cx="100" cy="76" r="8" fill="#818cf8" opacity="0.15"/>
  <circle cx="100" cy="73" r="3" fill="#6366f1" opacity="0.4"/>
  <path d="M94 82a6 6 0 0112 0" fill="#6366f1" opacity="0.2"/>
  <!-- Cost formula -->
  <rect x="34" y="100" width="78" height="20" rx="4" fill="#6366f1" opacity="0.06"/>
  <text x="73" y="114" text-anchor="middle" font-size="8" fill="#6366f1" font-family="Inter, sans-serif">$12 x 3 = $36/mo</text>
  <!-- Note -->
  <text x="73" y="142" text-anchor="middle" font-size="7" fill="#9ca3af" font-family="Inter, sans-serif">Scales with team</text>

  <!-- Usage-based model -->
  <rect x="147" y="20" width="106" height="140" rx="10" fill="white" stroke="#c7d2fe" stroke-width="1.5"/>
  <rect x="147" y="20" width="106" height="32" rx="10" fill="url(#pm-grad)"/>
  <rect x="147" y="42" width="106" height="10" fill="url(#pm-grad)"/>
  <text x="200" y="42" text-anchor="middle" font-size="10" fill="#6366f1" font-family="Inter, sans-serif" font-weight="600">Usage-based</text>
  <!-- Usage graph -->
  <polyline points="162,92 174,88 186,80 198,72 210,78 222,68 234,60" stroke="#6366f1" stroke-width="2" fill="none" stroke-linecap="round"/>
  <line x1="162" y1="92" x2="234" y2="92" stroke="#e5e7eb" stroke-width="1"/>
  <circle cx="234" cy="60" r="3" fill="#6366f1"/>
  <!-- Cost -->
  <rect x="161" y="100" width="78" height="20" rx="4" fill="#6366f1" opacity="0.06"/>
  <text x="200" y="114" text-anchor="middle" font-size="8" fill="#6366f1" font-family="Inter, sans-serif">Pay for what you use</text>
  <text x="200" y="142" text-anchor="middle" font-size="7" fill="#9ca3af" font-family="Inter, sans-serif">Can spike unexpectedly</text>

  <!-- Flat-rate model -->
  <rect x="274" y="20" width="106" height="140" rx="10" fill="white" stroke="#c7d2fe" stroke-width="1.5"/>
  <rect x="274" y="20" width="106" height="32" rx="10" fill="url(#pm-grad)"/>
  <rect x="274" y="42" width="106" height="10" fill="url(#pm-grad)"/>
  <text x="327" y="42" text-anchor="middle" font-size="10" fill="#6366f1" font-family="Inter, sans-serif" font-weight="600">Flat-rate</text>
  <!-- Flat line -->
  <line x1="290" y1="76" x2="362" y2="76" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round"/>
  <circle cx="290" cy="76" r="3" fill="#6366f1" opacity="0.3"/>
  <circle cx="326" cy="76" r="3" fill="#6366f1" opacity="0.3"/>
  <circle cx="362" cy="76" r="3" fill="#6366f1" opacity="0.3"/>
  <!-- Cost -->
  <rect x="288" y="100" width="78" height="20" rx="4" fill="#6366f1" opacity="0.06"/>
  <text x="327" y="114" text-anchor="middle" font-size="8" fill="#6366f1" font-family="Inter, sans-serif">$49/mo — always</text>
  <text x="327" y="142" text-anchor="middle" font-size="7" fill="#9ca3af" font-family="Inter, sans-serif">Predictable cost</text>
</svg>
