---
/**
 * Free tools badge / gift concept for the free tools guide
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 200" class={`w-full max-w-md mx-auto ${className}`} aria-hidden="true">
  <defs>
    <linearGradient id="fb-bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#6366f1" stop-opacity="0.06"/>
      <stop offset="100%" stop-color="#34d399" stop-opacity="0.04"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <ellipse cx="200" cy="100" rx="170" ry="85" fill="url(#fb-bg)"/>

  <!-- Central "$0" badge -->
  <circle cx="200" cy="94" r="40" fill="white" stroke="#6366f1" stroke-width="2" filter="drop-shadow(0 2px 8px rgba(99,102,241,0.1))"/>
  <text x="200" y="90" text-anchor="middle" font-size="24" font-weight="700" fill="#6366f1" font-family="Inter, sans-serif">$0</text>
  <text x="200" y="106" text-anchor="middle" font-size="9" fill="#818cf8" font-family="Inter, sans-serif">/month</text>

  <!-- Orbiting tool cards -->
  <!-- Card 1: CRM -->
  <rect x="54" y="44" width="64" height="40" rx="6" fill="white" stroke="#c7d2fe" stroke-width="1" filter="drop-shadow(0 1px 4px rgba(0,0,0,0.04))"/>
  <rect x="62" y="52" width="28" height="4" rx="2" fill="#818cf8" opacity="0.4"/>
  <rect x="62" y="60" width="46" height="3" rx="1.5" fill="#e5e7eb"/>
  <rect x="62" y="68" width="36" height="3" rx="1.5" fill="#e5e7eb" opacity="0.6"/>
  <circle cx="110" cy="50" r="6" fill="#34d399" opacity="0.2"/>
  <text x="110" y="53" text-anchor="middle" font-size="7" fill="#34d399" font-family="Inter, sans-serif" font-weight="700">F</text>

  <!-- Card 2: PM -->
  <rect x="286" y="36" width="64" height="40" rx="6" fill="white" stroke="#c7d2fe" stroke-width="1" filter="drop-shadow(0 1px 4px rgba(0,0,0,0.04))"/>
  <rect x="294" y="44" width="28" height="4" rx="2" fill="#818cf8" opacity="0.4"/>
  <rect x="294" y="52" width="46" height="3" rx="1.5" fill="#e5e7eb"/>
  <rect x="294" y="60" width="36" height="3" rx="1.5" fill="#e5e7eb" opacity="0.6"/>
  <circle cx="342" cy="42" r="6" fill="#34d399" opacity="0.2"/>
  <text x="342" y="45" text-anchor="middle" font-size="7" fill="#34d399" font-family="Inter, sans-serif" font-weight="700">F</text>

  <!-- Card 3: Design -->
  <rect x="62" y="120" width="64" height="40" rx="6" fill="white" stroke="#c7d2fe" stroke-width="1" filter="drop-shadow(0 1px 4px rgba(0,0,0,0.04))"/>
  <rect x="70" y="128" width="28" height="4" rx="2" fill="#818cf8" opacity="0.4"/>
  <rect x="70" y="136" width="46" height="3" rx="1.5" fill="#e5e7eb"/>
  <rect x="70" y="144" width="36" height="3" rx="1.5" fill="#e5e7eb" opacity="0.6"/>
  <circle cx="118" cy="126" r="6" fill="#34d399" opacity="0.2"/>
  <text x="118" y="129" text-anchor="middle" font-size="7" fill="#34d399" font-family="Inter, sans-serif" font-weight="700">F</text>

  <!-- Card 4: Analytics -->
  <rect x="278" y="120" width="64" height="40" rx="6" fill="white" stroke="#c7d2fe" stroke-width="1" filter="drop-shadow(0 1px 4px rgba(0,0,0,0.04))"/>
  <rect x="286" y="128" width="28" height="4" rx="2" fill="#818cf8" opacity="0.4"/>
  <rect x="286" y="136" width="46" height="3" rx="1.5" fill="#e5e7eb"/>
  <rect x="286" y="144" width="36" height="3" rx="1.5" fill="#e5e7eb" opacity="0.6"/>
  <circle cx="334" cy="126" r="6" fill="#34d399" opacity="0.2"/>
  <text x="334" y="129" text-anchor="middle" font-size="7" fill="#34d399" font-family="Inter, sans-serif" font-weight="700">F</text>

  <!-- Dashed connection lines to center -->
  <line x1="118" y1="64" x2="162" y2="82" stroke="#c7d2fe" stroke-width="1" stroke-dasharray="3 3" opacity="0.4"/>
  <line x1="286" y1="56" x2="238" y2="82" stroke="#c7d2fe" stroke-width="1" stroke-dasharray="3 3" opacity="0.4"/>
  <line x1="126" y1="140" x2="162" y2="110" stroke="#c7d2fe" stroke-width="1" stroke-dasharray="3 3" opacity="0.4"/>
  <line x1="278" y1="140" x2="238" y2="110" stroke="#c7d2fe" stroke-width="1" stroke-dasharray="3 3" opacity="0.4"/>

  <!-- Bottom text -->
  <text x="200" y="188" text-anchor="middle" font-size="9" fill="#6366f1" font-family="Inter, sans-serif" opacity="0.5">Genuinely useful free tiers</text>
</svg>
