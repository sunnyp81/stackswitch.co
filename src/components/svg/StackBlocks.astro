---
/**
 * Tech stack building blocks — shows layered SaaS tools as interlocking blocks
 * Used in "building your tech stack" guide
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 220" class={`w-full max-w-md mx-auto ${className}`} aria-hidden="true">
  <defs>
    <linearGradient id="sb-1" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#6366f1"/>
      <stop offset="100%" stop-color="#4f46e5"/>
    </linearGradient>
    <linearGradient id="sb-2" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#818cf8"/>
      <stop offset="100%" stop-color="#6366f1"/>
    </linearGradient>
  </defs>

  <!-- Foundation layer (Infrastructure) -->
  <rect x="60" y="160" width="280" height="40" rx="6" fill="url(#sb-1)" opacity="0.9"/>
  <text x="200" y="184" text-anchor="middle" font-size="11" fill="white" font-family="Inter, sans-serif" font-weight="600">Infrastructure & Security</text>

  <!-- Middle layer blocks (Core tools) -->
  <rect x="60" y="112" width="134" height="40" rx="6" fill="url(#sb-2)" opacity="0.7"/>
  <text x="127" y="136" text-anchor="middle" font-size="10" fill="white" font-family="Inter, sans-serif" font-weight="600">CRM & Sales</text>

  <rect x="206" y="112" width="134" height="40" rx="6" fill="#818cf8" opacity="0.5"/>
  <text x="273" y="136" text-anchor="middle" font-size="10" fill="white" font-family="Inter, sans-serif" font-weight="600">Communication</text>

  <!-- Upper blocks (Specialised) -->
  <rect x="60" y="64" width="86" height="40" rx="6" fill="#818cf8" opacity="0.35"/>
  <text x="103" y="88" text-anchor="middle" font-size="9" fill="#4f46e5" font-family="Inter, sans-serif" font-weight="600">Analytics</text>

  <rect x="157" y="64" width="86" height="40" rx="6" fill="#a5b4fc" opacity="0.4"/>
  <text x="200" y="88" text-anchor="middle" font-size="9" fill="#4f46e5" font-family="Inter, sans-serif" font-weight="600">Design</text>

  <rect x="254" y="64" width="86" height="40" rx="6" fill="#c7d2fe" opacity="0.5"/>
  <text x="297" y="88" text-anchor="middle" font-size="9" fill="#4f46e5" font-family="Inter, sans-serif" font-weight="600">HR & Payroll</text>

  <!-- Top blocks (Nice-to-haves) -->
  <rect x="110" y="20" width="76" height="36" rx="6" fill="#e0e7ff" opacity="0.6"/>
  <text x="148" y="42" text-anchor="middle" font-size="8" fill="#6366f1" font-family="Inter, sans-serif" font-weight="600">SEO Tools</text>

  <rect x="198" y="20" width="96" height="36" rx="6" fill="#e0e7ff" opacity="0.5"/>
  <text x="246" y="42" text-anchor="middle" font-size="8" fill="#6366f1" font-family="Inter, sans-serif" font-weight="600">Social Media</text>

  <!-- Connection lines between layers -->
  <line x1="127" y1="104" x2="127" y2="112" stroke="#818cf8" stroke-width="1" opacity="0.3"/>
  <line x1="273" y1="104" x2="273" y2="112" stroke="#818cf8" stroke-width="1" opacity="0.3"/>
  <line x1="200" y1="56" x2="200" y2="64" stroke="#c7d2fe" stroke-width="1" opacity="0.3"/>

  <!-- Arrow indicating growth -->
  <path d="M370 180v-156" stroke="#c7d2fe" stroke-width="1.5" fill="none" stroke-dasharray="4 3" opacity="0.4"/>
  <path d="M366 30l4-10 4 10" stroke="#c7d2fe" stroke-width="1.5" fill="none" opacity="0.4"/>
  <text x="370" y="14" text-anchor="middle" font-size="7" fill="#a5b4fc" font-family="Inter, sans-serif">Scale</text>
</svg>
