---
/**
 * Ascending pricing tier columns for pricing pages
 * Visual metaphor: growing value as tiers increase
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 180" class={`w-full max-w-md mx-auto ${className}`} aria-hidden="true">
  <defs>
    <linearGradient id="tier-1" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#818cf8" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="#818cf8" stop-opacity="0.05"/>
    </linearGradient>
    <linearGradient id="tier-2" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#6366f1" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="#6366f1" stop-opacity="0.08"/>
    </linearGradient>
    <linearGradient id="tier-3" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#6366f1" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="#4f46e5" stop-opacity="0.2"/>
    </linearGradient>
    <linearGradient id="tier-4" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#4f46e5"/>
      <stop offset="100%" stop-color="#6366f1"/>
    </linearGradient>
  </defs>

  <!-- Base line -->
  <line x1="30" y1="160" x2="370" y2="160" stroke="#e5e7eb" stroke-width="1.5"/>

  <!-- Tier 1: Free -->
  <rect x="40" y="120" width="70" height="40" rx="8" fill="url(#tier-1)" stroke="#c7d2fe" stroke-width="1"/>
  <text x="75" y="138" text-anchor="middle" font-size="10" fill="#818cf8" font-family="Inter, sans-serif" font-weight="600">Free</text>
  <text x="75" y="152" text-anchor="middle" font-size="8" fill="#a5b4fc" font-family="Inter, sans-serif">$0/mo</text>

  <!-- Tier 2: Starter -->
  <rect x="125" y="86" width="70" height="74" rx="8" fill="url(#tier-2)" stroke="#a5b4fc" stroke-width="1"/>
  <text x="160" y="108" text-anchor="middle" font-size="10" fill="#6366f1" font-family="Inter, sans-serif" font-weight="600">Starter</text>
  <text x="160" y="122" text-anchor="middle" font-size="8" fill="#818cf8" font-family="Inter, sans-serif">$12/mo</text>
  <!-- Feature dots -->
  <circle cx="145" cy="138" r="2" fill="#818cf8" opacity="0.4"/>
  <rect x="150" y="136" width="22" height="3" rx="1.5" fill="#818cf8" opacity="0.2"/>
  <circle cx="145" cy="148" r="2" fill="#818cf8" opacity="0.4"/>
  <rect x="150" y="146" width="18" height="3" rx="1.5" fill="#818cf8" opacity="0.2"/>

  <!-- Tier 3: Pro (highlighted) -->
  <rect x="210" y="46" width="70" height="114" rx="8" fill="url(#tier-3)" stroke="#6366f1" stroke-width="1.5"/>
  <!-- Popular badge -->
  <rect x="218" y="38" width="54" height="16" rx="8" fill="#6366f1"/>
  <text x="245" y="49" text-anchor="middle" font-size="7" fill="white" font-family="Inter, sans-serif" font-weight="600">POPULAR</text>
  <text x="245" y="72" text-anchor="middle" font-size="10" fill="#4f46e5" font-family="Inter, sans-serif" font-weight="700">Pro</text>
  <text x="245" y="86" text-anchor="middle" font-size="8" fill="#6366f1" font-family="Inter, sans-serif">$49/mo</text>
  <!-- Feature dots -->
  <circle cx="228" cy="102" r="2" fill="#6366f1" opacity="0.5"/>
  <rect x="233" y="100" width="24" height="3" rx="1.5" fill="#6366f1" opacity="0.3"/>
  <circle cx="228" cy="112" r="2" fill="#6366f1" opacity="0.5"/>
  <rect x="233" y="110" width="20" height="3" rx="1.5" fill="#6366f1" opacity="0.3"/>
  <circle cx="228" cy="122" r="2" fill="#6366f1" opacity="0.5"/>
  <rect x="233" y="120" width="26" height="3" rx="1.5" fill="#6366f1" opacity="0.3"/>
  <!-- CTA -->
  <rect x="222" y="136" width="46" height="14" rx="7" fill="#6366f1" opacity="0.3"/>
  <rect x="230" y="141" width="30" height="4" rx="2" fill="white" opacity="0.5"/>

  <!-- Tier 4: Enterprise -->
  <rect x="295" y="24" width="70" height="136" rx="8" fill="url(#tier-4)"/>
  <text x="330" y="52" text-anchor="middle" font-size="10" fill="white" font-family="Inter, sans-serif" font-weight="700">Enterprise</text>
  <text x="330" y="66" text-anchor="middle" font-size="8" fill="white" font-family="Inter, sans-serif" opacity="0.8">Custom</text>
  <!-- Feature dots -->
  <circle cx="313" cy="84" r="2" fill="white" opacity="0.5"/>
  <rect x="318" y="82" width="24" height="3" rx="1.5" fill="white" opacity="0.3"/>
  <circle cx="313" cy="94" r="2" fill="white" opacity="0.5"/>
  <rect x="318" y="92" width="20" height="3" rx="1.5" fill="white" opacity="0.3"/>
  <circle cx="313" cy="104" r="2" fill="white" opacity="0.5"/>
  <rect x="318" y="102" width="26" height="3" rx="1.5" fill="white" opacity="0.3"/>
  <circle cx="313" cy="114" r="2" fill="white" opacity="0.5"/>
  <rect x="318" y="112" width="22" height="3" rx="1.5" fill="white" opacity="0.3"/>
  <!-- CTA -->
  <rect x="307" y="132" width="46" height="14" rx="7" fill="white" opacity="0.2"/>
  <rect x="315" y="137" width="30" height="4" rx="2" fill="white" opacity="0.4"/>

  <!-- Ascending arrow hint -->
  <path d="M380 155l6-12 6 12" stroke="#c7d2fe" stroke-width="1.5" fill="none" opacity="0.4"/>
</svg>
