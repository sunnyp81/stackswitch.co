---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
}

const { title, description, canonical, schema } = Astro.props;
const url = canonical ?? Astro.url.href;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "StackSwitch",
  "url": "https://stackswitch.co",
  "description": "Independent SaaS comparison directory. Find alternatives, compare pricing, and switch with confidence.",
  "publisher": {
    "@type": "Organization",
    "name": "StackSwitch",
    "url": "https://stackswitch.co"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://stackswitch.co/alternatives/{search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

const schemas = [websiteSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="StackSwitch" />
  <meta property="og:image" content="https://stackswitch.co/og-image.svg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://stackswitch.co/og-image.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(schemas)} />
  <meta name="msvalidate.01" content="F4F5EB5B902BBBE925DCC681F18545C1" />
</head>
<body class="bg-white text-gray-900 font-sans antialiased">
  <header class="border-b border-gray-100 sticky top-0 bg-white/95 backdrop-blur z-50">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="font-bold text-lg tracking-tight">
        <span class="text-indigo-600">stack</span>switch
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm text-gray-600">
        <a href="/category/crm" class="hover:text-gray-900">CRM</a>
        <a href="/category/project-management" class="hover:text-gray-900">Project Mgmt</a>
        <a href="/category/email-marketing" class="hover:text-gray-900">Email</a>
        <a href="/category/hr" class="hover:text-gray-900">HR</a>
        <a href="/category/analytics" class="hover:text-gray-900">Analytics</a>
        <a href="/guides" class="hover:text-gray-900 font-medium text-indigo-600">Guides</a>
      </nav>
      <button id="nav-toggle" class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.5" aria-label="Toggle navigation" aria-expanded="false">
        <span class="block w-6 h-0.5 bg-gray-700 transition-all duration-200" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-gray-700 transition-all duration-200" id="bar2"></span>
        <span class="block w-6 h-0.5 bg-gray-700 transition-all duration-200" id="bar3"></span>
      </button>
    </div>
    <div id="mobile-nav" class="hidden md:hidden border-t border-gray-100 bg-white/95 backdrop-blur px-4 py-3">
      <nav class="flex flex-col gap-1 text-sm text-gray-600">
        <a href="/category/crm" class="py-2 hover:text-gray-900">CRM</a>
        <a href="/category/project-management" class="py-2 hover:text-gray-900">Project Mgmt</a>
        <a href="/category/email-marketing" class="py-2 hover:text-gray-900">Email</a>
        <a href="/category/hr" class="py-2 hover:text-gray-900">HR</a>
        <a href="/category/analytics" class="py-2 hover:text-gray-900">Analytics</a>
        <a href="/guides" class="py-2 font-medium text-indigo-600">Guides</a>
      </nav>
    </div>
  </header>
  <script>
    const toggle = document.getElementById('nav-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    toggle?.addEventListener('click', () => {
      const open = mobileNav?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
    });
  </script>

  <main>
    <slot />
  </main>

  <footer class="border-t border-gray-100 mt-20 py-10 text-sm text-gray-500">
    <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row justify-between gap-4">
      <p>© {new Date().getFullYear()} StackSwitch. Independent software comparisons.</p>
      <nav class="flex gap-4">
        <a href="/about" class="hover:text-gray-900">About</a>
        <a href="/privacy" class="hover:text-gray-900">Privacy</a>
        <a href="/contact" class="hover:text-gray-900">Contact</a>
      </nav>
    </div>
  </footer>
</body>
</html>
